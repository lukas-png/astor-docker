# =============================================================================
# RepairThemAll (Astor) replication manifest — sourced by the top-level build.sh.
#
# Each replication under replications/<name>/ ships one of these. build.sh reads
# it to learn what to tag, what to fetch, and what must be vendored. To add a new
# replication, drop a folder with a Dockerfile, a resources/ dir and this file.
# =============================================================================

# Local image tag prefix -> ${IMAGE}:<version>, e.g. astor:1.4.0
IMAGE="astor"

# Remote registry for --push (override via $REGISTRY in the environment).
REGISTRY="${REGISTRY:-ghcr.io/lukas-png/docker-astor}"

# Versions to build. Passed to the Dockerfile as --build-arg <VERSION_BUILD_ARG>.
BUILDS=("1.4.0")
VERSION_BUILD_ARG="D4J_VERSION"

# Vendored, pinned artefacts that MUST already exist in resources/ — committed to
# Git on purpose so the RepairThemAll replication stays locked to one version.
# build.sh never downloads these; a missing one (or a sha256 mismatch) is a hard
# error.
VENDORED=(astor.jar jtestex7.jar d4j-compliance.tsv)

# --- Astor jar provenance (see README.md "Astor jar selection") ----------------
# The pinned astor.jar is the revision that PRODUCED the published Defects4J
# results of the RepairThemAll experiment (all runs Nov-Dec 2018). It is NOT the
# jar that program-repair/RepairThemAll serves on `master` today: master carries a
# later, post-experiment rebuild (edcbfc8, 2019-01-02, built from SpoonLabs/astor
# 26ee3dfc8b2d7ed4373f7cfe0d4bd5bcf31d9f28). Pinning the experiment jar pins the
# replication to the version used in the experiment.
ASTOR_SRC_REPO="program-repair/RepairThemAll"
ASTOR_JAR_COMMIT="e902cf54f84a059379d9abfd6159d502963511cc"   # 2018-11-04 "new astor version"
ASTOR_JAR_PATH="repair_tools/astor.jar"                        # Spoon 7.0.0, built JDK 1.8.0_181

# sha256 of each vendored artefact, verified by build.sh check_vendored.
declare -A SHA256SUMS=(
  [astor.jar]="8ab2a8acc8bf263b62c77b594f0ea1ba8a61469d20b33f27aa76fadf563cf51a"
  [jtestex7.jar]="c47cd132bb594875c934c75fb51c6aef7e327b1da98aaf216630193d4cf0b2ff"
  # Defects4J source-compliance table — generate with scripts/gen-compliance-table.
  [d4j-compliance.tsv]="08ad0c8f19f262479b13d35e4aa2cdf5dfc94fb2cd117ca418a3a71c0a35320f"
)

# Resources fetched on demand into resources/ when absent (large/redistributable,
# pinned by a stable versioned URL). Format: "<file>|<url>|<fallback-local-path>"
RESOURCES=(
  "zulu8.78.0.19-ca-jdk8.0.412-linux_x64.tar.gz|https://cdn.azul.com/zulu/bin/zulu8.78.0.19-ca-jdk8.0.412-linux_x64.tar.gz|"
)
