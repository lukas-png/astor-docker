#!/usr/bin/env bash
# sync-reference-results
#
# Refresh reference/Defects4J/ from the published RepairThemAll_experiment, pinned
# to one commit. Keeps, for the four Astor modes, result.json + detailed-result.json
# and the run logs beside them (repair.log, grid5k.stderr.log) The
# subset is committed; re-running must produce no diff unless the pin is bumped.
set -euo pipefail

REPL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
REPO="https://github.com/program-repair/RepairThemAll_experiment.git"
COMMIT="a59cd3c85864a5f21dc6bc1e71920abbdc9379fd"
MODES=(jGenProg jKali jMutRepair Cardumen)
DEST="$REPL_DIR/reference/Defects4J"

tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
git clone --quiet --filter=blob:none --no-checkout --sparse "$REPO" "$tmp/exp"
cd "$tmp/exp"
git sparse-checkout init --no-cone >/dev/null
patterns=()
for m in "${MODES[@]}"; do
    patterns+=("results/Defects4J/*/*/$m/*/result.json"
               "results/Defects4J/*/*/$m/*/detailed-result.json"
               "results/Defects4J/*/*/$m/*/repair.log"
               "results/Defects4J/*/*/$m/*/grid5k.stderr.log")
done
git sparse-checkout set --no-cone "${patterns[@]}" >/dev/null
git -c advice.detachedHead=false checkout --quiet "$COMMIT"

rm -rf "$DEST"; mkdir -p "$DEST"
n=0
declare -A seen_dir
while IFS= read -r -d '' f; do
    rel="${f#results/Defects4J/}"
    dir="$(dirname "$rel")"
    mkdir -p "$DEST/$dir"
    cp -f "$f" "$DEST/$rel"; n=$((n + 1))
    seen_dir["$dir"]=1
done < <(find results/Defects4J -type f \( -name result.json -o -name detailed-result.json \) -print0)

logs=0
for dir in "${!seen_dir[@]}"; do
    for lg in repair.log grid5k.stderr.log; do
        [ -f "results/Defects4J/$dir/$lg" ] || continue
        cp -f "results/Defects4J/$dir/$lg" "$DEST/$dir/$lg"; logs=$((logs + 1))
    done
done
echo "synced $n result files + $logs log files -> reference/Defects4J  (pinned @ ${COMMIT:0:10})"
