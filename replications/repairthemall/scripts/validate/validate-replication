#!/usr/bin/env python3
"""validate-replication [--modes M] [--csv FILE] [--json FILE] [--strict] [--show N]

Per-bug check that the local runs reproduce the published reference, at several
tiers (noise such as timestamps/paths/timing is ignored):

  OUTCOME    : same result (patched vs not), and the same {location, operator,
               original->patched code} when patched.
  TRAJECTORY : additionally identical NR_GENERATIONS / NR_RIGHT_COMPILATIONS /
               NR_FAILLING_COMPILATIONS (deterministic run).
  EXACT      : report-only. For patched bugs also the modification-point fields
               (LINE, SUSPICIOUNESS, MP_RANKING, the *_TYPE / INGREDIENT_*
               fields); for every bug general.OUTPUT_STATUS. Path/timestamp noise
               is excluded; differences are listed but do not affect the exit code.
  LOG        : report-only. Fields only in the run log (local astor.log vs
               reference repair.log), not result.json: run parameters, Gzoltar
               suspiciousness, dependency jar-set, per-line suspiciousness. Bugs
               upstream produced no result for but we ran locally: REF_NO_RESULT.

Prints match rates + any mismatch, writes a per-bug CSV (--csv) and/or a corpus
summary JSON (--json), exits non-zero if any compared bug disagrees on OUTCOME
(--strict also fails on not-yet-run bugs). Only OUTCOME affects the exit code;
TRAJECTORY/EXACT/LOG are diagnostic.
Default mode jGenProg; --modes jKali,Cardumen,... or 'all'.
"""
import argparse
import csv
import json
import os
import re
import sys
from collections import Counter

MODES = ["jGenProg", "jKali", "jMutRepair", "Cardumen"]


def norm(s):
    return None if s is None else " ".join(str(s).split()).rstrip(";").strip()


def load(path):
    try:
        with open(path) as fd:
            return json.load(fd)
    except (IOError, ValueError):
        return None


# LOG tier: fields that live only in the run log (local astor.log vs reference
# repair.log, same markers)
LOG_SUBFIELDS = ("params", "deps", "susp", "line_susp")

# logical param -> source keys to try (p:<key>= wins over the echoed CLI args,
# where e.g. maxGeneration is spelled -maxgen).
LOG_PARAM_KEYS = {
    "mode": ("mode",), "scope": ("scope",), "seed": ("seed",),
    "population": ("population",),
    "maxgeneration": ("maxgeneration", "maxgen"),
    "javacompliancelevel": ("javacompliancelevel",),
    "limitbysuspicious": ("limitbysuspicious",),
}
_P_RE = re.compile(r"p:(\w+)=\s?(.*?)\s*$")
_CLI_RE = re.compile(r"command line arguments:\s*\[(.*)\]")
_SUSP_RES = {
    "min_susp": re.compile(r"min susp value parameter:\s*([\d.]+)"),
    "gzoltar_suspicious": re.compile(r"GZoltar suspicious\s+(\d+)"),
    "positive_susp": re.compile(r"with positive susp\s+(\d+)"),
    "found": re.compile(r"Gzoltar found:\s*(\d+)\s+with susp"),
    "considered": re.compile(r"we consider:\s*(\d+)"),
    "initial_suspicious_size": re.compile(r"Initial suspicious size:\s*(\d+)"),
}
_LINESUSP_RE = re.compile(r"lineSuspiciousness=\s*([\d.]+)")


def _jars(depstr):
    return sorted({os.path.basename(p) for p in (depstr or "").split(":")
                   if p.strip().endswith(".jar")})


def parse_log(path):
    """Comparable fields from an Astor run log (local astor.log / reference
    repair.log -- same markers). None if the log is absent or empty."""
    try:
        with open(path, errors="replace") as fd:
            text = fd.read()
    except IOError:
        return None
    if not text:
        return None

    p_vals, cli = {}, {}
    for line in text.splitlines():
        m = _P_RE.search(line)
        if m:
            p_vals[m.group(1).lower()] = m.group(2).strip()
    mc = _CLI_RE.search(text)
    if mc:
        toks = mc.group(1).split()
        i = 0
        while i < len(toks):
            if toks[i].startswith("-"):
                nxt = toks[i + 1] if i + 1 < len(toks) else ""
                cli[toks[i].lstrip("-").lower()] = "" if nxt.startswith("-") else nxt
                i += 1 if nxt.startswith("-") else 2
            else:
                i += 1
    src = dict(cli)
    src.update(p_vals)   # p: lines win over the echoed CLI

    params = {}
    for logical, cands in LOG_PARAM_KEYS.items():
        for c in cands:
            if c in src:
                params[logical] = src[c]
                break

    susp = {}
    for k, rx in _SUSP_RES.items():
        m = rx.search(text)
        susp[k] = m.group(1) if m else None
    deps = _jars(p_vals.get("dependenciespath") or cli.get("dependencies"))
    return {"parameters": params, "suspiciousness": susp,
            "dependencies": deps,
            "line_suspiciousness": _LINESUSP_RE.findall(text)}


def log_compare(local_log, ref_log):
    """Per-subfield state (match/diff/na) + human diff detail for the LOG tier."""
    states = {k: "na" for k in LOG_SUBFIELDS}
    if not local_log or not ref_log:
        return states, ""
    detail = []

    lp, rp = local_log["parameters"], ref_log["parameters"]
    pdiff = ["%s local=%r ref=%r" % (k, lp.get(k), rp.get(k))
             for k in sorted(set(lp) | set(rp)) if lp.get(k) != rp.get(k)]
    states["params"] = "diff" if pdiff else "match"
    if pdiff:
        detail.append("params: " + "; ".join(pdiff))

    ld, rd = set(local_log["dependencies"]), set(ref_log["dependencies"])
    states["deps"] = "match" if ld == rd else "diff"
    if ld != rd:
        detail.append("deps: +local%s -ref%s" % (sorted(ld - rd), sorted(rd - ld)))

    ls, rs = local_log["suspiciousness"], ref_log["suspiciousness"]
    sdiff = ["%s local=%s ref=%s" % (k, ls.get(k), rs.get(k))
             for k in _SUSP_RES if ls.get(k) != rs.get(k)]
    states["susp"] = "diff" if sdiff else "match"
    if sdiff:
        detail.append("susp: " + "; ".join(sdiff))

    lc, rc = Counter(local_log["line_suspiciousness"]), Counter(ref_log["line_suspiciousness"])
    states["line_susp"] = "match" if lc == rc else "diff"
    if lc != rc:
        detail.append("line_susp: local_n=%d ref_n=%d" % (sum(lc.values()), sum(rc.values())))

    return states, " | ".join(detail)


def load_coverage(base):
    """(project, bug) -> (has_result, upstream_status) from the committed
    reference/coverage-jGenProg.csv (jGenProg only). {} if absent."""
    path = os.path.join(base, "reference", "coverage-jGenProg.csv")
    out = {}
    try:
        with open(path, newline="") as fd:
            for r in csv.DictReader(fd):
                out[(r["project"], r["bug"])] = (r.get("has_result") == "1",
                                                 r.get("upstream_status") or "")
    except IOError:
        return {}
    return out


def patch_set(data):
    return frozenset((h.get("LOCATION"), h.get("OPERATOR"),
                      norm(h.get("ORIGINAL_CODE")), norm(h.get("PATCH_HUNK_CODE")))
                     for p in (data.get("patches") or [])
                     for h in (p.get("patchhunks") or []))


EXACT_FIELDS = ["LOCATION", "OPERATOR", "LINE", "SUSPICIOUNESS", "MP_RANKING",
                "BUGGY_CODE_TYPE", "PATCH_HUNK_TYPE", "INGREDIENT_SCOPE",
                "INGREDIENT_PARENT", "ORIGINAL_CODE", "PATCH_HUNK_CODE"]
CODE_FIELDS = {"ORIGINAL_CODE", "PATCH_HUNK_CODE", "INGREDIENT_PARENT"}


def exact_hunks(data):
    return [{f: (norm(h.get(f)) if f in CODE_FIELDS else h.get(f))
             for f in EXACT_FIELDS}
            for p in (data.get("patches") or [])
            for h in (p.get("patchhunks") or [])]


def exact_compare(local, ref):
    lh, rh = local["exact"], ref["exact"]
    if len(lh) == 1 and len(rh) == 1:
        diffs = ["%s local=%r ref=%r" % (f, lh[0].get(f), rh[0].get(f))
                 for f in EXACT_FIELDS if lh[0].get(f) != rh[0].get(f)]
        return ("diff", "; ".join(diffs)) if diffs else ("match", "")
    fs = lambda hs: frozenset(tuple(h.get(f) for f in EXACT_FIELDS) for h in hs)
    if fs(lh) == fs(rh):
        return ("match", "")
    return ("diff", "hunk set differs (%d vs %d hunks)" % (len(lh), len(rh)))


def trajectory(data):
    g = data.get("general")
    if not g:
        return None
    v = (g.get("NR_GENERATIONS"), g.get("NR_RIGHT_COMPILATIONS"), g.get("NR_FAILLING_COMPILATIONS"))
    return None if any(x is None for x in v) else v


def summarize(data):
    if data is None:
        return None
    ps = patch_set(data)
    return {"patched": len(ps) > 0, "patches": ps, "traj": trajectory(data),
            "status": (data.get("general") or {}).get("OUTPUT_STATUS"),
            "exact": exact_hunks(data)}


def classify(local, ref):
    if local is None:
        return ("MISSING_LOCAL", None, "na", "na", "")
    if local["patched"] != ref["patched"]:
        return ("OUTCOME_DIFF", False, "na", "na", "")
    if local["patched"] and local["patches"] != ref["patches"]:
        return ("PATCH_DIFF", False, "na", "na", "")
    exact_state, exact_diff = exact_compare(local, ref)
    if local.get("status") != ref.get("status"):
        sd = "OUTPUT_STATUS local=%r ref=%r" % (local.get("status"), ref.get("status"))
        exact_diff = (exact_diff + "; " + sd) if exact_diff else sd
        exact_state = "diff"
    if local["traj"] is None or ref["traj"] is None:
        klass = "MATCH_OUTCOME" if local["patched"] else "MATCH_NOPATCH"
        return (klass, True, "na", exact_state, exact_diff)
    if local["traj"] == ref["traj"]:
        return ("MATCH_TRAJECTORY", True, "match", exact_state, exact_diff)
    return ("MATCH_OUTCOME_TRAJ_DIFF", True, "diff", exact_state, exact_diff)


def main():
    ap = argparse.ArgumentParser(description="Validate Astor replication vs reference.")
    ap.add_argument("--modes", default="jGenProg", help="subset of %s, or 'all'" % ",".join(MODES))
    ap.add_argument("--csv")
    ap.add_argument("--json", help="write a corpus summary JSON (tiers + per-bug rows)")
    ap.add_argument("--strict", action="store_true", help="also fail on not-yet-run bugs")
    ap.add_argument("--show", type=int, default=20)
    args = ap.parse_args()

    modes = MODES if args.modes == "all" else [m for m in args.modes.split(",") if m]
    base = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
    ref_root = os.path.join(base, "reference", "Defects4J")
    res_root = os.path.join(base, "results")
    if not os.path.isdir(ref_root):
        sys.exit("no reference (run scripts/reference/sync-reference-results)")

    cov = load_coverage(base)

    rows = []
    for project in sorted(os.listdir(ref_root)):
        pdir = os.path.join(ref_root, project)
        if not os.path.isdir(pdir):
            continue
        for bug in sorted(os.listdir(pdir), key=lambda x: (len(x), x)):
            for mode in modes:
                seed = os.path.join(pdir, bug, mode, "0")
                ref_data = load(os.path.join(seed, "detailed-result.json")) \
                    or load(os.path.join(seed, "result.json"))
                if ref_data is None:
                    continue
                ref = summarize(ref_data)
                local_dir = os.path.join(res_root, "%s-%s" % (project, bug), mode)
                local = summarize(load(os.path.join(local_dir, "astor_output.json")))
                klass, outcome_ok, traj, exact_state, exact_diff = classify(local, ref)
                # LOG tier: local astor.log vs reference repair.log (if we ran it).
                local_log = parse_log(os.path.join(local_dir, "astor.log")) \
                    if local is not None else None
                ref_log = parse_log(os.path.join(seed, "repair.log"))
                log_states, log_diff = log_compare(local_log, ref_log)
                rows.append({"project": project, "bug": bug, "mode": mode,
                             "local_present": local is not None,
                             "ref_patched": ref["patched"],
                             "local_patched": (local or {}).get("patched"),
                             "outcome_ok": outcome_ok,
                             "traj_ref": ref["traj"], "traj_local": (local or {}).get("traj"),
                             "traj_state": traj, "classification": klass,
                             "exact_state": exact_state, "exact_diff_fields": exact_diff,
                             "log_params_state": log_states["params"],
                             "log_deps_state": log_states["deps"],
                             "log_susp_state": log_states["susp"],
                             "log_line_susp_state": log_states["line_susp"],
                             "log_diff_fields": log_diff,
                             "upstream_status": cov.get((project, bug), (None, ""))[1]})

    # Bugs upstream produced no result for (absent from reference/) but that we ran
    # locally: surface them with the upstream reason. jGenProg only (coverage scope).
    if "jGenProg" in modes:
        seen = {(r["project"], r["bug"]) for r in rows if r["mode"] == "jGenProg"}
        for (project, bug), (has_result, status) in sorted(cov.items()):
            if has_result or (project, bug) in seen:
                continue
            local_dir = os.path.join(res_root, "%s-%s" % (project, bug), "jGenProg")
            local = summarize(load(os.path.join(local_dir, "astor_output.json")))
            if local is None:
                continue   # neither ref nor local: pure upstream accounting
            rows.append({"project": project, "bug": bug, "mode": "jGenProg",
                         "local_present": True, "ref_patched": None,
                         "local_patched": local["patched"], "outcome_ok": None,
                         "traj_ref": None, "traj_local": local["traj"],
                         "traj_state": "na", "classification": "REF_NO_RESULT",
                         "exact_state": "na", "exact_diff_fields": "",
                         "log_params_state": "na", "log_deps_state": "na",
                         "log_susp_state": "na", "log_line_susp_state": "na",
                         "log_diff_fields": "ref no result (upstream %s)" % status,
                         "upstream_status": status})

    compared = [r for r in rows if r["outcome_ok"] in (True, False)]
    omatch = [r for r in compared if r["outcome_ok"] is True]
    odiff = [r for r in compared if r["outcome_ok"] is False]
    tcomp = [r for r in compared if r["traj_state"] in ("match", "diff")]
    tmatch = [r for r in tcomp if r["traj_state"] == "match"]
    ecomp = [r for r in compared if r["exact_state"] in ("match", "diff")]
    ematch = [r for r in ecomp if r["exact_state"] == "match"]
    missing = [r for r in rows if not r["local_present"]]
    ref_no_result = [r for r in rows if r["classification"] == "REF_NO_RESULT"]
    pct = lambda n, d: "%5.1f%%" % (100.0 * n / d) if d else "  n/a"

    def log_rate(field):
        comp = [r for r in compared if r[field] in ("match", "diff")]
        return sum(r[field] == "match" for r in comp), len(comp)

    print("== replication validation (Astor / Defects4J) -- modes: %s ==" % ",".join(modes))
    print("reference pairs: %d | compared: %d | missing locally: %d"
          % (len(rows) - len(ref_no_result), len(compared), len(missing)))
    print("  OUTCOME    identical: %d/%d  %s   (differ: %d)"
          % (len(omatch), len(compared), pct(len(omatch), len(compared)), len(odiff)))
    print("  TRAJECTORY identical: %d/%d  %s   (differ: %d)"
          % (len(tmatch), len(tcomp), pct(len(tmatch), len(tcomp)), len(tcomp) - len(tmatch)))
    print("  EXACT      identical: %d/%d  %s   (differ: %d, report-only)"
          % (len(ematch), len(ecomp), pct(len(ematch), len(ecomp)), len(ecomp) - len(ematch)))
    for field, label in (("log_params_state", "LOG params"),
                         ("log_deps_state", "LOG deps  "),
                         ("log_susp_state", "LOG susp  ")):
        m, d = log_rate(field)
        print("  %s identical: %d/%d  %s   (differ: %d, report-only)"
              % (label, m, d, pct(m, d), d - m))
    if ref_no_result:
        print("  REF_NO_RESULT (upstream produced none, ran locally): %d" % len(ref_no_result))
    counts = {}
    for r in rows:
        counts[r["classification"]] = counts.get(r["classification"], 0) + 1
    for k in sorted(counts):
        print("    %-26s %d" % (k, counts[k]))

    bad = [r for r in compared if r["classification"] in
           ("OUTCOME_DIFF", "PATCH_DIFF", "MATCH_OUTCOME_TRAJ_DIFF")]
    if bad:
        print("  mismatches (up to %d):" % args.show)
        for r in bad[:args.show]:
            extra = ("  local=%s ref=%s" % (r["traj_local"], r["traj_ref"])
                     if r["classification"] == "MATCH_OUTCOME_TRAJ_DIFF" else "")
            print("    %-9s %-4s %-10s %s%s" % (r["project"], r["bug"], r["mode"],
                                                r["classification"], extra))

    ediffs = [r for r in compared if r["exact_state"] == "diff"]
    if ediffs:
        print("  EXACT field diffs (report-only, up to %d):" % args.show)
        for r in ediffs[:args.show]:
            print("    %-9s %-4s %-10s %s" % (r["project"], r["bug"], r["mode"],
                                              r["exact_diff_fields"]))

    ldiffs = [r for r in compared if r["log_diff_fields"]]
    if ldiffs:
        print("  LOG diffs (report-only, up to %d):" % args.show)
        for r in ldiffs[:args.show]:
            print("    %-9s %-4s %-10s %s" % (r["project"], r["bug"], r["mode"],
                                              r["log_diff_fields"]))

    if args.csv and rows:
        with open(args.csv, "w", newline="") as fd:
            w = csv.DictWriter(fd, fieldnames=list(rows[0].keys()))
            w.writeheader(); w.writerows(rows)
        print("  csv: %s" % args.csv)

    if args.json:
        lp_m, lp_d = log_rate("log_params_state")
        ld_m, ld_d = log_rate("log_deps_state")
        ls_m, ls_d = log_rate("log_susp_state")
        rate = lambda n, d: round(n / d, 4) if d else None
        summary = {
            "modes": modes,
            "totals": {"reference_pairs": len(rows) - len(ref_no_result),
                       "compared": len(compared), "missing_local": len(missing),
                       "ref_no_result": len(ref_no_result)},
            "tiers": {
                "outcome": {"compared": len(compared), "identical": len(omatch),
                            "differ": len(odiff), "rate": rate(len(omatch), len(compared))},
                "trajectory": {"compared": len(tcomp), "identical": len(tmatch),
                               "differ": len(tcomp) - len(tmatch), "rate": rate(len(tmatch), len(tcomp))},
                "exact": {"compared": len(ecomp), "identical": len(ematch),
                          "differ": len(ecomp) - len(ematch), "rate": rate(len(ematch), len(ecomp))},
                "log_params": {"compared": lp_d, "identical": lp_m, "differ": lp_d - lp_m, "rate": rate(lp_m, lp_d)},
                "log_deps": {"compared": ld_d, "identical": ld_m, "differ": ld_d - ld_m, "rate": rate(ld_m, ld_d)},
                "log_susp": {"compared": ls_d, "identical": ls_m, "differ": ls_d - ls_m, "rate": rate(ls_m, ls_d)},
            },
            "classifications": counts,
            "bugs": [{k: (list(v) if isinstance(v, (tuple, frozenset)) else v)
                      for k, v in r.items()} for r in rows],
        }
        with open(args.json, "w") as fd:
            json.dump(summary, fd, indent=2, sort_keys=True)
        print("  json: %s" % args.json)

    return 1 if odiff or (args.strict and missing) else 0


if __name__ == "__main__":
    sys.exit(main())
