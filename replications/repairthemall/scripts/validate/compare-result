#!/usr/bin/env python3
"""compare-result <Project>-<BugId> [mode]

Quick single-bug check: compare a collected local run against the reference for
one mode (default jGenProg), on the substantive fields only. For the full corpus
use validate-replication.
"""
import json
import os
import sys

MODE_DIR = {"jgenprog": "jGenProg", "jkali": "jKali",
            "jmutrepair": "jMutRepair", "cardumen": "Cardumen"}


def norm(s):
    return None if s is None else " ".join(str(s).split()).rstrip(";").strip()


def load(path):
    try:
        with open(path) as fd:
            return json.load(fd)
    except (IOError, ValueError):
        return None


def summary(data):
    if not data:
        return None
    patches = data.get("patches") or []
    if not patches:
        return {"patched": False, "status": (data.get("general") or {}).get("OUTPUT_STATUS")}
    h = (patches[0].get("patchhunks") or [{}])[0]
    return {"patched": True,
            "status": (data.get("general") or {}).get("OUTPUT_STATUS"),
            "location": h.get("LOCATION"), "operator": h.get("OPERATOR"),
            "change": "%s  ->  %s" % (norm(h.get("ORIGINAL_CODE")), norm(h.get("PATCH_HUNK_CODE"))),
            "key": (h.get("LOCATION"), h.get("OPERATOR"),
                    norm(h.get("ORIGINAL_CODE")), norm(h.get("PATCH_HUNK_CODE")))}


def main():
    if len(sys.argv) < 2:
        sys.exit(__doc__)
    bug = sys.argv[1]
    mode = (sys.argv[2] if len(sys.argv) > 2 else "jgenprog").lower()
    if mode not in MODE_DIR:
        sys.exit("unknown mode %r (%s)" % (mode, ", ".join(MODE_DIR)))
    project, bug_id = bug.split("-", 1)
    base = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

    local = summary(load(os.path.join(base, "results", "%s-%s" % (project, bug_id),
                                      MODE_DIR[mode], "astor_output.json")))
    ref = summary(load(os.path.join(base, "reference", "Defects4J", project, bug_id,
                                    MODE_DIR[mode], "0", "detailed-result.json")))
    if local is None:
        sys.exit("no local run for %s %s (run it, then collect-results)" % (bug, mode))
    if ref is None:
        sys.exit("no reference for %s %s" % (bug, mode))

    def fmt(s):
        return ("no patch (%s)" % s.get("status") if not s["patched"]
                else "patch @ %s (%s)\n               change: %s"
                     % (s["location"], s["operator"], s["change"]))

    print("Bug %s   mode %s" % (bug, MODE_DIR[mode]))
    print("  local     : %s" % fmt(local))
    print("  reference : %s" % fmt(ref))
    if local["patched"] and ref["patched"]:
        if local["key"] == ref["key"]:
            print("  => MATCH (same location, operator, code change)"); return 0
        print("  => DIFFER (same bug patched differently)"); return 1
    if local["patched"] == ref["patched"]:
        print("  => MATCH (both: no patch)"); return 0
    print("  => MISMATCH (one patched, the other not)"); return 1


if __name__ == "__main__":
    sys.exit(main())
